<div class="wfe-panel__content">
  <div class="wfe-toggle-row">
    <label>{{localize "WFE.Field.Enabled"}}</label>
    <input
      type="checkbox"
      class="wfe-enabled-toggle"
      {{#if engineEnabled}}checked{{/if}}
      {{#unless canManage}}disabled{{/unless}}
    />
  </div>

  {{#if engineEnabled}}
  <div class="wfe-panel__header">
    <div>
      <h3>{{localize "WFE.Sheet.Title"}}</h3>
      {{#if summary}}
        <p class="wfe-panel__summary">{{summary}}</p>
      {{/if}}
    </div>
    {{#if isManaged}}
      <button type="button" class="wfe-initialize-rule" {{#unless canManage}}disabled{{/unless}}>
        {{buttonLabels.initialize}}
      </button>
    {{/if}}
  </div>

  <div class="wfe-panel__assign">
    <label class="wfe-field">
      <span>{{localize "WFE.Field.Rule"}}</span>
      <select class="wfe-rule-select" {{#unless canManage}}disabled{{/unless}}>
        <option value="">{{localize "WFE.Prompt.SelectRule"}}</option>
        {{#each ruleChoices as |rule|}}
          <option value="{{rule.id}}" {{#if rule.selected}}selected{{/if}}>{{rule.label}}</option>
        {{/each}}
      </select>
    </label>
    <button type="button" class="wfe-assign-rule" {{#unless canManage}}disabled{{/unless}}>
      {{buttonLabels.assignRule}}
    </button>
  </div>

  <div class="wfe-group">
    <div class="wfe-group__title">{{localize "WFE.Group.ItemDetails"}}</div>
    <div class="wfe-edit-grid">
      <label class="wfe-field wfe-field--compact">
        <span>{{localize "WFE.Field.WeaponType"}}</span>
        <input type="text" value="{{itemDetails.weaponType}}" data-wfe-item-field="weaponType" {{#unless canManage}}disabled{{/unless}} />
      </label>
      <label class="wfe-field wfe-field--compact">
        <span>{{localize "WFE.Field.ActionType"}}</span>
        <input type="text" value="{{itemDetails.actionType}}" data-wfe-item-field="actionType" {{#unless canManage}}disabled{{/unless}} />
      </label>
      <label class="wfe-field wfe-field--compact">
        <span>{{localize "WFE.Field.Ability"}}</span>
        <input type="text" value="{{itemDetails.ability}}" data-wfe-item-field="ability" {{#unless canManage}}disabled{{/unless}} />
      </label>
      <label class="wfe-field wfe-field--compact">
        <span>{{localize "WFE.Field.AttackBonus"}}</span>
        <input type="text" value="{{itemDetails.attackBonus}}" data-wfe-item-field="attackBonus" {{#unless canManage}}disabled{{/unless}} />
      </label>
      <label class="wfe-field wfe-field--compact">
        <span>{{localize "WFE.Field.AttackFlat"}}</span>
        <input type="checkbox" {{#if itemDetails.attackFlat}}checked{{/if}} data-wfe-item-field="attackFlat" data-wfe-value-type="boolean" {{#unless canManage}}disabled{{/unless}} />
      </label>
      <label class="wfe-field wfe-field--compact">
        <span>{{localize "WFE.Field.MagicalBonus"}}</span>
        <input type="number" value="{{itemDetails.magicalBonus}}" data-wfe-item-field="magicalBonus" data-wfe-value-type="number" {{#unless canManage}}disabled{{/unless}} />
      </label>
      <label class="wfe-field">
        <span>{{localize "WFE.Field.DamageFormula"}}</span>
        <input type="text" value="{{itemDetails.damageFormula}}" data-wfe-item-field="damageFormula" {{#unless canManage}}disabled{{/unless}} />
      </label>
      <label class="wfe-field wfe-field--compact">
        <span>{{localize "WFE.Field.DamageType"}}</span>
        <input type="text" value="{{itemDetails.damageType}}" data-wfe-item-field="damageType" {{#unless canManage}}disabled{{/unless}} />
      </label>
      <label class="wfe-field">
        <span>{{localize "WFE.Field.VersatileDamage"}}</span>
        <input type="text" value="{{itemDetails.versatileDamage}}" data-wfe-item-field="versatileDamage" {{#unless canManage}}disabled{{/unless}} />
      </label>
      <label class="wfe-field wfe-field--compact">
        <span>{{localize "WFE.Field.RangeValue"}}</span>
        <input type="number" value="{{itemDetails.rangeValue}}" data-wfe-item-field="rangeValue" data-wfe-value-type="number" {{#unless canManage}}disabled{{/unless}} />
      </label>
      <label class="wfe-field wfe-field--compact">
        <span>{{localize "WFE.Field.RangeLong"}}</span>
        <input type="number" value="{{itemDetails.rangeLong}}" data-wfe-item-field="rangeLong" data-wfe-value-type="number" {{#unless canManage}}disabled{{/unless}} />
      </label>
      <label class="wfe-field wfe-field--compact">
        <span>{{localize "WFE.Field.RangeUnits"}}</span>
        <input type="text" value="{{itemDetails.rangeUnits}}" data-wfe-item-field="rangeUnits" {{#unless canManage}}disabled{{/unless}} />
      </label>
      <label class="wfe-field wfe-field--wide">
        <span>{{localize "WFE.Field.ChatFlavor"}}</span>
        <input type="text" value="{{itemDetails.chatFlavor}}" data-wfe-item-field="chatFlavor" {{#unless canManage}}disabled{{/unless}} />
      </label>
    </div>
  </div>

  <div class="wfe-group">
    <div class="wfe-group__title">{{localize "WFE.Group.CustomRule"}}</div>
    <p class="wfe-panel__summary">{{localize "WFE.Message.CustomRuleHelp"}}</p>
    <textarea class="wfe-json-starter-source" hidden>{{starterRuleSource}}</textarea>
    <textarea class="wfe-json-managed-source" hidden>{{managedRuleSource}}</textarea>
    {{#if hasCustomRule}}
      <p class="wfe-panel__note">{{localize "WFE.Message.CustomRuleActive"}} <strong>{{customRuleLabel}}</strong></p>
    {{/if}}
    <label class="wfe-field">
      <span>{{localize "WFE.Field.CustomRuleJson"}}</span>
      <textarea class="wfe-json-input" rows="16" spellcheck="false" {{#unless canManage}}disabled{{/unless}}>{{customRuleSource}}</textarea>
    </label>
    <div class="wfe-button-row">
      <button type="button" class="wfe-assign-json-rule" {{#unless canManage}}disabled{{/unless}}>
        {{buttonLabels.applyJsonRule}}
      </button>
      <button type="button" class="wfe-load-starter-rule" {{#unless canManage}}disabled{{/unless}}>
        {{buttonLabels.loadStarterRule}}
      </button>
      {{#if isManaged}}
        <button type="button" class="wfe-load-managed-rule" {{#unless canManage}}disabled{{/unless}}>
          {{buttonLabels.loadManagedRule}}
        </button>
      {{/if}}
    </div>
  </div>

  {{#if isManaged}}
    <div class="wfe-status-grid">
      <div class="wfe-card">
        <div class="wfe-card__label">{{localize "WFE.Field.Form"}}</div>
        <div class="wfe-card__value">{{currentForm}}</div>
      </div>
      <div class="wfe-card">
        <div class="wfe-card__label">{{localize "WFE.Field.State"}}</div>
        <div class="wfe-card__value">{{currentState}}</div>
      </div>
      <div class="wfe-card">
        <div class="wfe-card__label">{{localize "WFE.Field.AttackBonus"}}</div>
        <div class="wfe-card__value">{{attackBonus}}</div>
      </div>
      <div class="wfe-card">
        <div class="wfe-card__label">{{localize "WFE.Field.Range"}}</div>
        <div class="wfe-card__value">{{rangeLabel}}</div>
      </div>
      <div class="wfe-card wfe-card--wide">
        <div class="wfe-card__label">{{localize "WFE.Field.Damage"}}</div>
        <div class="wfe-card__value">{{damageSummary}}</div>
      </div>
    </div>

    {{#if hasActions}}
      <div class="wfe-group">
        <div class="wfe-group__title">{{localize "WFE.Group.Actions"}}</div>
        <div class="wfe-button-row">
          {{#each actions as |action|}}
            <button type="button" data-wfe-action-id="{{action.id}}" {{#unless ../canManage}}disabled{{/unless}}>
              {{action.label}}
            </button>
          {{/each}}
          {{#if showConfirmHit}}
            <button type="button" class="wfe-confirm-hit" {{#unless canManage}}disabled{{/unless}}>
              {{buttonLabels.confirmHit}}
            </button>
          {{/if}}
          {{#if showTimerCheck}}
            <button type="button" class="wfe-check-timers" {{#unless canManage}}disabled{{/unless}}>
              {{buttonLabels.checkTimers}}
            </button>
          {{/if}}
        </div>
      </div>
    {{/if}}

    {{#if hasCounters}}
      <div class="wfe-group">
        <div class="wfe-group__title">{{localize "WFE.Group.Counters"}}</div>
        <ul class="wfe-list">
          {{#each counters as |counter|}}
            <li><strong>{{counter.label}}:</strong> {{counter.value}}</li>
          {{/each}}
        </ul>
      </div>
    {{/if}}

    {{#if hasTimers}}
      <div class="wfe-group">
        <div class="wfe-group__title">{{localize "WFE.Group.Timers"}}</div>
        <ul class="wfe-list">
          {{#each timers as |timer|}}
            <li><strong>{{timer.label}}:</strong> {{timer.value}}</li>
          {{/each}}
        </ul>
      </div>
    {{/if}}

    {{#if hasRestrictions}}
      <div class="wfe-group">
        <div class="wfe-group__title">{{localize "WFE.Group.Restrictions"}}</div>
        <ul class="wfe-list">
          {{#each restrictions as |restriction|}}
            <li>{{restriction.label}}</li>
          {{/each}}
        </ul>
      </div>
    {{/if}}

    {{#if hasPassives}}
      <div class="wfe-group">
        <div class="wfe-group__title">{{localize "WFE.Group.Passives"}}</div>
        <ul class="wfe-list">
          {{#each passives as |passive|}}
            <li>{{passive.label}}</li>
          {{/each}}
        </ul>
      </div>
    {{/if}}
  {{else}}
    <p class="wfe-panel__empty">{{localize "WFE.Message.UnmanagedItem"}}</p>
  {{/if}}
  {{else}}
    <p class="wfe-panel__empty">{{localize "WFE.Message.DisabledItem"}}</p>
  {{/if}}
</div>
